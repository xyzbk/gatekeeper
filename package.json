{
  "name": "gatekeeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first repository intelligence for Codex.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "tsc -b --pretty false --force && pnpm --filter @gatekeeper/dashboard build",
    "demo": "tsx demo/judge-demo.ts",
    "judge": "pnpm install --frozen-lockfile && pnpm build && pnpm demo:smoke && pnpm demo",
    "demo:seed": "tsx demo/scripts/seed-github.ts",
    "demo:smoke": "tsx demo/evaluate.ts --smoke",
    "eval": "tsx demo/evaluate.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixtures:prepare": "tsx demo/prepare-fixtures.ts",
    "lint": "eslint packages apps demo tests playwright.config.ts --max-warnings 0",
    "model-data:dry-run": "tsx demo/model-data-dry-run.ts",
    "schema:verdict": "pnpm --filter @gatekeeper/contracts schema:verdict",
    "test": "vitest run --config vitest.workspace.ts",
    "typecheck": "tsc -b --pretty false && pnpm --filter @gatekeeper/dashboard typecheck && tsc --noEmit --pretty false -p tsconfig.playwright.json"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
